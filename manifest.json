{
  "manifest_version": 3,
  "name": "Lazy Remix Filter",
  "version": "1.1.14",
  "description": "Hide or highlight lazy remix videos on YouTube and YouTube Music using title-based block and allow lists.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "https://m.youtube.com/*",
    "https://music.youtube.com/*"
  ],
  "action": {
    "default_title": "Lazy Remix Filter — open options",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*",
        "https://m.youtube.com/*"
      ],
      "js": ["lib/filter.js", "lib/content-common.js", "content/youtube.js"],
      "run_at": "document_end",
      "all_frames": false
    },
    {
      "matches": ["https://music.youtube.com/*"],
      "js": ["lib/filter.js", "lib/content-common.js", "content/ytmusic.js"],
      "run_at": "document_end",
      "all_frames": false
    }
  ]
}
